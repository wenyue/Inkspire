{
  "name": "inkspire",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "start": "npm run start --workspace server",
    "test": "npm test --workspaces --if-present",
    "test:server": "npm test --workspace server",
    "test:client": "npm test --workspace client",
    "e2e": "node scripts/run-e2e.cjs",
    "verify:real": "node scripts/verify-real-generation.js",
    "curate:classic-artworks": "node scripts/apply-classic-artwork-curation.mjs",
    "validate:classic-artworks": "node scripts/validate-classic-artworks.mjs",
    "test:selector-assets": "node --test scripts/selector-asset-contract.test.mjs",
    "validate:selector-assets": "node scripts/validate-selector-assets.mjs",
    "contact-sheet:selector-assets": "node scripts/build-selector-contact-sheet.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "concurrently": "^8.2.2",
    "opencc-js": "^1.4.0"
  }
}
